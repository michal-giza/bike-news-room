	<!-- ============================================================
	     Layer 1 native flags — flutter-ads-consent skill
	     Disable Firebase Analytics + Crashlytics + AdMob measurement
	     at native SDK load time, BEFORE any Dart code can run.
	     Re-enabled in Dart only after ATT + UMP are completed.
	     ============================================================ -->

	<!-- Firebase Analytics: deactivated at SDK load. Use the *_ENABLED
	     form, NEVER *_DEACTIVATED — the latter is irreversible. -->
	<key>FIREBASE_ANALYTICS_COLLECTION_ENABLED</key>
	<false/>

	<!-- Firebase Crashlytics: collection off until post-consent. -->
	<key>FirebaseCrashlyticsCollectionEnabled</key>
	<false/>

	<!-- AdMob: do not start the internal app-measurement pipeline
	     until we explicitly initialize MobileAds post-consent. -->
	<key>GADDelayAppMeasurementInit</key>
	<true/>

	<!-- Google Analytics consent-v2 default-deny (IAB TCF). -->
	<key>GOOGLE_ANALYTICS_DEFAULT_ALLOW_ANALYTICS_STORAGE</key>
	<false/>
	<key>GOOGLE_ANALYTICS_DEFAULT_ALLOW_AD_STORAGE</key>
	<false/>
	<key>GOOGLE_ANALYTICS_DEFAULT_ALLOW_AD_USER_DATA</key>
	<false/>
	<key>GOOGLE_ANALYTICS_DEFAULT_ALLOW_AD_PERSONALIZATION_SIGNALS</key>
	<false/>

